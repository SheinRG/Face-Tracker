# ── Face Detection System — Environment Variables ──────────────────────
# Copy this file to .env and adjust values as needed.

# PostgreSQL credentials (shared by db and backend services)
POSTGRES_USER=facedetect
POSTGRES_PASSWORD=facedetect
POSTGRES_DB=facedetect

# Backend (only needed if running outside Docker)
POSTGRES_HOST=db
POSTGRES_PORT=5432
APP_TITLE=Face Detection API
APP_VERSION=1.0.0
